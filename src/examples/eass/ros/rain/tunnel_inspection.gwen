EASS
:abstraction: debug_bot

:Initial Beliefs:
//robot initial pose x:-8, y: -3, z: 0

location_coordinate(location1, -8, -2.0, 0.0)
location_coordinate(location2, -8.0, -3.2, 0.0)

:Initial Goals:
move(location1) [perform]

:Plans:
+!move(L) [perform] : { B location_coordinate(L, X, Y, Z) } <-
    print("Attempting to move to ", L),
    move(X, Y, Z);

+movebase_result(1,3) : { True } <-
    print("Move completed.");
